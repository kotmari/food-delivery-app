generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id        String    @id @default(uuid())
  name      String
  address   String
  rating    Float     @default(4.0)
  image_url String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Product {
  id         String   @id @default(uuid())
  name       String
  price      Float
  image_url  String?
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id          String   @id @default(uuid())
  userName    String
  userEmail   String
  userPhone   String
  userAddress String
  totalPrice  Float
  items       Json
  createdAt   DateTime @default(now())
}
